  const [allowed, setAllowed] = useState(false);
  const [isCreator, setIsCreator] = useState(false);
  const [communityName, setCommunityName] = useState<string | null>(null);
  const [activities, setActivities] = useState<ActivityRow[]>([]);
  const [warning, setWarning] = useState<string | null>(null);

  const [selectedSport, setSelectedSport] = useState<string | null>(
    routeSport
  );
  const [selectedDate, setSelectedDate] = useState<string | null>(null);
  const [calendarMonth, setCalendarMonth] = useState(
    () => new Date(new Date().getFullYear(), new Date().getMonth(), 1)
  );

  useEffect(() => {
    let cancelled = false;

    async function loadPage() {
      if (!communityId || typeof communityId !== "string") {
        router.replace("/groups");
        return;
      }

      setLoading(true);
      setWarning(null);

      try {
        const {
          data: { user },
        } = await supabase.auth.getUser();

        if (!user) {
          router.replace("/login");
          return;
        }

        const { data: community, error: communityError } = await supabase
          .from("app_membership_communities")
          .select("id,name,created_by")
          .eq("id", communityId)
          .single();

        if (communityError || !community) {
          router.replace("/groups");
          return;
        }

        const typedCommunity = community as CommunityRow;
        const creator = typedCommunity.created_by === user.id;

        if (!creator) {
          const { data: membershipRequest } = await supabase
            .from("app_membership_requests")
            .select("status")
            .eq("community_id", communityId)
            .eq("user_id", user.id)
            .maybeSingle();

          if (
            !membershipRequest ||
            !["approved", "active"].includes(membershipRequest.status)
          ) {
            router.replace(`/groups/${communityId}`);
            return;
          }
        }

        const nowIso = new Date().toISOString();

        const { data: eventRows, error: eventsError } = await supabase
          .from("app_activities")
          .select(
            "id,title,sport,activity_type,description,start_date,address_text,city,state,capacity,image_path,image_url,published,community_id"
          )
          .eq("published", true)
          .eq("community_id", communityId)
          .gte("start_date", nowIso)
          .order("start_date", { ascending: true });

        if (cancelled) return;

        if (eventsError) {
          console.error("Error loading community events:", eventsError);
          setActivities([]);
          setWarning("I couldn't load the events right now.");
        } else {
          const typedRows = (eventRows ?? []) as ActivityRow[];
          setActivities(typedRows);

          if (typedRows.length === 0) {
            setWarning("No upcoming events for this community.");
          }
        }

        setCommunityName(typedCommunity.name ?? null);
        setIsCreator(creator);
        setAllowed(true);
      } catch (error) {
        console.error("Unexpected error loading community events:", error);

        if (!cancelled) {
          setActivities([]);
          setWarning("Failed to connect to Supabase.");
        }
      } finally {
        if (!cancelled) {
          setLoading(false);
        }
      }
    }

    loadPage();

    return () => {
      cancelled = true;
    };
  }, [communityId, router, supabase]);

  const activitiesBySport = useMemo(() => {
    const grouped = new Map<string, ActivityRow[]>();

    for (const activity of activities) {
      const sportName = normalizeSport(activity);
      const existing = grouped.get(sportName) ?? [];
      existing.push(activity);
      grouped.set(sportName, existing);
    }

    return grouped;
  }, [activities]);

  const visibleSports = useMemo(
    () =>
      SPORTS.filter(
        (sport) => (activitiesBySport.get(sport.name)?.length ?? 0) > 0
      ),
    [activitiesBySport]
  );

  const selectedSportActivities = useMemo(() => {
    if (!selectedSport) return [];
    return activitiesBySport.get(selectedSport) ?? [];
  }, [activitiesBySport, selectedSport]);

  const eventDateKeys = useMemo(
    () =>
      new Set(
        selectedSportActivities
          .filter((activity) => activity.start_date)
          .map((activity) => dateKey(activity.start_date as string))
      ),
    [selectedSportActivities]
  );

  const selectedDateActivities = useMemo(() => {
    if (!selectedDate) return [];

    return selectedSportActivities.filter(
      (activity) =>
        activity.start_date && dateKey(activity.start_date) === selectedDate
    );
  }, [selectedDate, selectedSportActivities]);

  const calendarCells = useMemo(
    () => getCalendarCells(calendarMonth),
    [calendarMonth]
  );

