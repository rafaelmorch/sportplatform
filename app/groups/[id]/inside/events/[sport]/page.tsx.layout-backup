                      border: "1px solid #e2e8f0",
                      background:
                        "linear-gradient(180deg, #ffffff 0%, #f8fafc 100%)",
                      boxShadow:
                        "5px 5px 16px rgba(148,163,184,0.10), -4px -4px 12px rgba(255,255,255,0.9)",
                    }}
                  >
                    <div
                      style={{
                        display: "flex",
                        alignItems: "center",
                        justifyContent: "space-between",
                        gap: 12,
                        marginBottom: 10,
                      }}
                    >
                      <span
                        style={{
                          borderRadius: 999,
                          padding: "6px 10px",
                          background: "#0f172a",
                          color: "#ffffff",
                          fontSize: 11,
                          fontWeight: 800,
                        }}
                      >
                        {formatEventTime(activity.start_date)}
                      </span>

                      <span
                        style={{
                          color: "#94a3b8",
                          fontSize: 20,
                          lineHeight: 1,
                        }}
                      >
                        ›
                      </span>
                    </div>

                    <h2
                      style={{
                        margin: "0 0 7px 0",
                        color: "#0f172a",
                        fontSize: 17,
                        fontWeight: 800,
                        lineHeight: 1.25,
                      }}
                    >
                      {activity.title ?? "Event"}
                    </h2>

                    <p
                      style={{
                        margin: 0,
                        color: "#64748b",
                        fontSize: 12,
                        lineHeight: 1.5,
                      }}
                    >
                      {buildAddress(activity)}
                    </p>

                    {activity.description && (
                      <p
                        style={{
                          margin: "10px 0 0 0",
                          color: "#475569",
                          fontSize: 13,
                          lineHeight: 1.5,
                          display: "-webkit-box",
                          WebkitLineClamp: 2,
                          WebkitBoxOrient: "vertical",
                          overflow: "hidden",
                        }}
                      >
                        {activity.description}
                      </p>
                    )}
                  </article>
                </Link>
              ))}
            </section>
          )}
        </div>
      </main>
    </>
  );
}




