  return (
    <button
      type="button"
      className="intro-card"
      onClick={onClick}
      style={
        {
          "--accent": palette.main,
          "--accent-border": palette.border,
          "--accent-glow": palette.glow,
          "--accent-soft": palette.soft,
        } as React.CSSProperties
      }
    >
      <div className="card-pattern" />

      <div className="card-icon">
        {icon}
      </div>

      <div className="card-content">
